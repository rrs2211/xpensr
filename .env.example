# ── Supabase (Required) ────────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...anon_key_here

# Service role key — NEVER prefix with VITE_ (must NOT be accessible in browser)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...service_key_here

# ── Super Admin (Required) ─────────────────────────────────────────────────────
# Credentials for the root super-admin login
VITE_SA_EMAIL=your-admin@yourdomain.com
VITE_SA_PASS=choose-a-strong-password-here

# ── AI Features (Optional — disabled by default) ──────────────────────────────
# Set to "true" to enable AI invoice OCR and chat assistant
VITE_AI_ENABLED=false
# Get from: https://console.anthropic.com
ANTHROPIC_KEY=sk-ant-api03-...your_key_here

# ── Notifications (Optional) ──────────────────────────────────────────────────
# Resend email — https://resend.com/api-keys
RESEND_API_KEY=re_...your_key_here

# Interakt WhatsApp — https://app.interakt.ai → Settings → API Keys
INTERAKT_API_KEY=your_interakt_key_here

# ── Security (Required in production) ─────────────────────────────────────────
# Your deployed domain — used to lock CORS on API routes
# Comma-separated for multiple (e.g. staging + prod)
ALLOWED_ORIGIN=https://xpensr.in

# ── IMPORTANT NOTES ───────────────────────────────────────────────────────────
# 1. NEVER commit .env or any file containing real keys to git
# 2. VITE_* variables are bundled into the client — only safe for public keys
# 3. SUPABASE_SERVICE_ROLE_KEY, ANTHROPIC_KEY, RESEND_API_KEY, INTERAKT_API_KEY
#    must NOT have the VITE_ prefix — they are server-side only
# 4. Rotate all keys immediately if any are accidentally committed
